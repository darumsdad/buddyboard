# Supabase Transaction pooler URL (port 6543) — used by the app at runtime
DATABASE_URL=

# Supabase direct connection URL (port 5432) — used by drizzle-kit migrate only
DATABASE_URL_DIRECT=

# 32+ character random string for signing session cookies
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Production app URL (e.g. https://buddyboard.vercel.app)
# Used by Better Auth for redirect URLs
BETTER_AUTH_URL=

# Same as BETTER_AUTH_URL — exposed to the browser for auth client baseURL
NEXT_PUBLIC_APP_URL=
